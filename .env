# =============================================================================
# .env.example  —  xray-docker environment configuration
#
# Copy this file to .env and edit it before running docker compose up.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# ttyd web terminal
# -----------------------------------------------------------------------------

# Basic authentication for the browser terminal.
# Format:  username:password
# STRONGLY recommended — anyone who can reach port 7681 can otherwise run
# the setup wizard and control your server with no password at all.
TTYD_CREDENTIAL=admin:changeme

# Port the browser terminal listens on (inside and outside the container).
# If you change this, also update the port mapping in docker-compose.yml.
TTYD_PORT=7681

# -----------------------------------------------------------------------------
# xray.sh behaviour
# -----------------------------------------------------------------------------

# Skip the external port-80 reachability check that xray.sh runs before
# calling certbot for the HTTP-01 ACME challenge.
#
# WHY THIS EXISTS:
#   xray.sh verifies port 80 by curling its own domain from inside the
#   container. With Docker bridge networking the traffic goes:
#     container → docker0 bridge → host public IP → docker port mapping → container
#   This "hairpin NAT" loopback works on most modern Linux hosts with
#   Docker's default iptables rules, but fails on some cloud providers and
#   older kernels.
#
# SET TO true IF:
#   - The wizard hangs or fails at "Verifying port 80 is reachable"
#   - You have already confirmed port 80 is open from the outside
#     (e.g. by testing with https://check-host.net or similar)
#
# The Let's Encrypt servers do their own check; this is only a pre-flight.
SKIP_PORT_CHECK=false
